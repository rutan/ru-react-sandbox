{
  "name": "ru-react-sandbox",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite preview",
    "dev": "vite",
    "build": "run-s build:*",
    "build:vite": "cross-env NODE_ENV=production vite build",
    "lint": "run-s lint:*",
    "lint:oxfmt": "oxfmt --check .",
    "lint:oxlint": "oxlint .",
    "lint:tsc": "tsgo",
    "format": "run-s format:*",
    "format:oxfmt": "oxfmt --write .",
    "format:oxlint": "oxlint --fix ."
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260130.1",
    "@vitejs/plugin-react": "^5.1.2",
    "cross-env": "^10.1.0",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.27.0",
    "oxlint": "^1.42.0",
    "oxlint-tsgolint": "^0.11.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "packageManager": "pnpm@10.28.2"
}
